@page
@model TronWallet.Web.Pages.Cabinet.HistoryModel
@{
    ViewData["Title"] = "Transaction History";
}

<div class="container mt-4">

    <div class="card shadow-sm">
        <div class="card-body">

            <h3 class="card-title mb-4">Transaction History</h3>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Type</th>
                            <th>Amount</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Status</th>
                            <th>Time</th>
                            <th>Tx</th>
                        </tr>
                    </thead>

                    <tbody>
                    @foreach (var tx in Model.Transactions)
                    {
                        var isIncoming = tx.Direction == "IN";

                        <tr>
                            <!-- Type -->
                            <td>
                                <span class="badge @(isIncoming ? "bg-success" : "bg-danger")">
                                    @(isIncoming ? "Incoming" : "Outgoing")
                                </span>
                            </td>

                            <!-- Amount -->
                            <td class="fw-bold @(isIncoming ? "text-success" : "text-danger")">
                                @(isIncoming ? "+" : "-") @tx.GetAmountTrx() TRX
                            </td>

                            <!-- From -->
                            <td class="text-muted">
                                @tx.FromAddress
                            </td>

                            <!-- To -->
                            <td class="text-muted">
                                @tx.ToAddress
                            </td>

                            <!-- Status -->
                            <td>
                                @if (tx.Status == "CONFIRMED")
                                {
                                    <span class="badge bg-success">Confirmed</span>
                                }
                                else if (tx.Status == "PENDING")
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Failed</span>
                                }
                            </td>

                            <!-- Time -->
                            <td>
                                <small class="text-muted">
                                    @tx.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                                </small>
                            </td>

                            <!-- Tx link -->
                            <td>
                                <a class="btn btn-sm btn-outline-primary"
                                   href="https://shasta.tronscan.org/#/transaction/@tx.TxHash"
                                   target="_blank">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            @if (!Model.Transactions.Any())
            {
                <div class="text-center text-muted mt-4">
                    No transactions yet.
                </div>
            }

        </div>
    </div>
</div>