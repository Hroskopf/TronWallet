@page
@model TronWallet.Web.Pages.Cabinet.SendModel
@{
    ViewData["Title"] = "Send TRX";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="card-title mb-4 text-center">Send TRX</h3>

                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="ToAddress" class="form-label"></label>
                            <input asp-for="ToAddress" class="form-control" placeholder="Enter TRON address" />
                            <span asp-validation-for="ToAddress" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label"></label>
                            <input asp-for="Amount" class="form-control" type="number" step="0.000001" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                Send TRX
                            </button>
                        </div>
                    </form>

                    @if (Model.Message != null)
                    {
                        <div class="alert alert-success mt-4">
                            @Model.Message
                        </div>
                    }

                    @if (Model.Error != null)
                    {
                        <div class="alert alert-danger mt-4">
                            @Model.Error
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}