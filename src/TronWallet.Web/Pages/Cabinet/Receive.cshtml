@page
@model TronWallet.Web.Pages.Cabinet.ReceiveModel
@{
    ViewData["Title"] = "Receive";
}

<div class="container mt-5">
    <div class="card shadow-sm mx-auto" style="max-width: 500px;">
        <div class="card-body text-center">

            <h4 class="card-title mb-3">Receive Funds</h4>
            <p class="text-muted">Scan the QR code or copy your wallet address</p>

            <!-- QR (CLICKABLE) -->
            <a href="https://shasta.tronscan.org/#/address/@Model.WalletAddress"
               target="_blank"
               class="d-inline-block p-3 bg-white border rounded text-decoration-none"
               style="cursor:pointer;">

                <div id="qrcode"></div>

                <div class="small text-muted mt-2">
                    Open in Tronscan
                </div>

            </a>

            <!-- Address -->
            <div class="mt-3">
                <input type="text" class="form-control text-center"
                       value="@Model.WalletAddress"
                       readonly
                       id="walletInput" />
            </div>

            <!-- Copy button -->
            <button class="btn btn-primary mt-3" onclick="copyAddress()">
                Copy Address
            </button>

        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const walletAddress = '@Model.WalletAddress';

    if (walletAddress && walletAddress.length > 0) {
        new QRCode(document.getElementById("qrcode"), {
            text: walletAddress,
            width: 200,
            height: 200
        });
    }
});

// Copy function
function copyAddress() {
    const input = document.getElementById("walletInput");
    input.select();
    input.setSelectionRange(0, 99999);
    navigator.clipboard.writeText(input.value);
}
</script>