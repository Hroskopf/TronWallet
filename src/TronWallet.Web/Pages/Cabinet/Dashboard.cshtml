@page
@model TronWallet.Web.Pages.Cabinet.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <h1 class="mb-4 text-center">Welcome, @Model.UserInfo.Username!</h1>

            <!-- Wallet Info -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title">Wallet Address</h5>
                    <p class="card-text">@Model.Wallet.TronAddress</p>

                    <h5 class="card-title mt-3">TRX Balance</h5>
                    <p class="card-text">@Model.Balance TRX</p>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class=" mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Actions</h5>
                    <a class="btn btn-primary me-2" href="/Cabinet/Send">Send TRX</a>
                    <a class="btn btn-secondary" href="/Cabinet/Receive">Receive TRX</a>
                </div>
            </div>

            <!-- Recent Transactions -->
            @* <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Recent Transactions</h5>

                    @if (Model.RecentTransactions != null && Model.RecentTransactions.Any())
